{
  "name": "facturaya",
  "version": "1.0.0",
  "description": "FacturaYa Pro Desktop",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron:start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.facturaya.app",
    "productName": "FacturaYa",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "dir",
      "icon": "public/favicon.ico"
    },
    "extraResources": [
      {
        "from": "database.sqlite",
        "to": "database.sqlite",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "pdfkit": "^0.18.0"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ]
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  }
}
